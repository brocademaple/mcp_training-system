# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database（本机运行时用 docker-compose 只起 postgres/redis，宿主机端口 5433）
DB_HOST=localhost
DB_PORT=5433
DB_USER=mcp_user
DB_PASSWORD=mcp_password
DB_NAME=mcp_training

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Storage
UPLOAD_DIR=./data/uploads
CLEANED_DIR=./data/cleaned
MODEL_DIR=./data/models
REPORT_DIR=./reports

# Python（本机运行方式：数据清洗/训练在本机执行，可使用 GPU）
# Windows 下若报 9009 请设为 python 或完整路径；Linux/Mac 可用 python3
PYTHON_PATH=python3
PYTHON_SCRIPTS_DIR=./python_scripts

# Agent 意图解析（可选）：rules=关键词规则（默认）；aliyun=仅阿里云通义 DashScope；hybrid=通义优先，失败则回退规则
# 通义使用 OpenAI 兼容接口：https://help.aliyun.com/zh/model-studio/developer-reference/use-qwen-by-calling-api
INTENT_RESOLVER_PROVIDER=rules
ALIYUN_DASHSCOPE_API_KEY=
ALIYUN_INTENT_MODEL=qwen-turbo
# 一般无需修改；新加坡等地域可换对应 compatible-mode 地址
ALIYUN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
